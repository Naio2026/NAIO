# QuickNode config (recommended for production)
# Preconfigured QuickNode endpoints (BSC mainnet)
QUICKNODE_HTTP_URL=https://<your-endpoint>.bsc.quiknode.pro/<token>/
QUICKNODE_WS_URL=wss://<your-endpoint>.bsc.quiknode.pro/<token>/

# Public BSC endpoints (fallback when USE_QUICKNODE=false)
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443

# ================================
# Time parameters (must match your contract/ops assumptions)
# ================================
# Optional: epoch duration (seconds)
# - Mainnet default: 86400 (1 day)
# - For testing you may temporarily set to 3600 (1 hour)
# If empty, defaults to 86400
# EPOCH_SECONDS=86400
#
# Optional: how many epochs make a "month" (used by withdraw unlock, monthly release ladder, etc.)
# - Mainnet default: 30 (1d/epoch => 30 days ≈ 1 month)
# - For testing you may reduce it (e.g. EPOCH_SECONDS=3600 and EPOCHS_PER_MONTH=5 => 5 hours ≈ 1 month)
# If empty, defaults to 30
# EPOCHS_PER_MONTH=30

# Contract addresses
USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
CONTROLLER_ADDRESS=
NODE_SEAT_POOL_ADDRESS=
INITIAL_POOL_SEEDER_ADDRESS=

# Keeper config (in distributed-signing mode, the server-side keeper aggregates signatures and submits on-chain)
KEEPER_PRIVATE_KEY=
# Keeper governor allowlist address (recommended: multisig; used to rotate/kick keeper)
KEEPER_GOVERNOR_ADDRESS=
# 3/3 witness signer addresses (deployment script writes these into the external rule engine)
WITNESS_SIGNER_1=
WITNESS_SIGNER_2=
WITNESS_SIGNER_3=
# Distributed signer allowlist addresses (JSON array or comma-separated; must be exactly 3)
# Example: ["0xabc...","0xdef...","0x123..."]
WITNESS_SIGNER_ADDRESSES=
# Witness signature deadline in seconds (default: 10 minutes)
WITNESS_SIGNATURE_DEADLINE_SECONDS=600
# Witness Hub (server-side) config: GUI signers fetch tasks and post signatures here
WITNESS_HUB_ENABLE=true
WITNESS_HUB_HOST=0.0.0.0
WITNESS_HUB_PORT=8787
# Strongly recommended: set to a high-entropy random secret
WITNESS_HUB_API_KEY=
# Worker polling interval (fetch signatures & submit on-chain) / task retention
WITNESS_WORKER_INTERVAL_SECONDS=2
WITNESS_TASK_RETENTION_SECONDS=7200

# Standalone signer service config (witness_signer/witness_signer_service.py; can run on separate servers)
# On the signer side, point to the Hub's public URL (not the Hub's bind/listen address)
WITNESS_HUB_SERVER_URL=
# Signer API key (usually the same as WITNESS_HUB_API_KEY)
WITNESS_SIGNER_API_KEY=
# Signer private key (one per signer server)
WITNESS_SIGNER_PRIVATE_KEY=
# Optional: expected signer address (guards against configuring the wrong private key)
WITNESS_SIGNER_EXPECTED_ADDRESS=
WITNESS_SIGNER_POLL_INTERVAL_SECONDS=2
WITNESS_SIGNER_HTTP_TIMEOUT_SECONDS=10
# Optional: standalone signer process can override dotenv path (default: backend/.env)
WITNESS_SIGNER_DOTENV_PATH=

# Optional: KeeperCouncil contract address (recommended: deploy once and reuse)
KEEPER_COUNCIL_ADDRESS=
# KeeperCouncil member addresses (5 members; used when deploying KeeperCouncil)
KEEPER_COUNCIL_MEMBER_1=
KEEPER_COUNCIL_MEMBER_2=
KEEPER_COUNCIL_MEMBER_3=
KEEPER_COUNCIL_MEMBER_4=
KEEPER_COUNCIL_MEMBER_5=
# Validator private key (independent of keeper; can veto/pause keeper accounting)
VALIDATOR_PRIVATE_KEY=

# ================================
# BSC testnet deployment params (Foundry)
# ================================
#
# Notes:
# - You only need to fill these variables in `/opt/naio/backend/.env` on the server
# - Then run the deployment script on the server (it will run `forge test` and `forge script ... --broadcast`)
#
# Minimum funding suggestion (testnet):
# - DEPLOYER_PRIVATE_KEY address: >= 0.2 BNB recommended (deploy + init 1000 node seats is gas-heavy)
# - KEEPER_PRIVATE_KEY address: >= 0.05 BNB recommended (listen deposits/refunds, call poke)
#
# Deployer private key (used to deploy contracts to BSC testnet)
DEPLOYER_PRIVATE_KEY=
# BSC testnet RPC (defaults to public RPC; you may replace with your own endpoint)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
#
# Fixed addresses (must be EOAs)
TRANSFER_TAX_RECEIVER_C=
ECO_A=
INDEPENDENT_B=
MARKET_E=
MARKET_F=

# Listener config
START_BLOCK=latest
POLL_INTERVAL=12

# High-throughput options (used by listen_deposits.py)
# Max blocks scanned per batch (faster catch-up when behind)
MAX_BLOCKS_PER_SCAN=2000
# eth_getLogs chunk size (blocks)
LOG_CHUNK_SIZE=200
# Number of threads for concurrent log fetching
LOG_FETCH_THREADS=8
# Threads for concurrent tx send / receipt wait (with nonce coordination)
TX_SEND_THREADS=2
# Max in-flight transactions (avoid overwhelming RPC/memory during spikes)
MAX_INFLIGHT_TXS=200
# Whether to wait for receipts (true = safer, false = higher throughput)
WAIT_FOR_RECEIPT=true
# Receipt timeout (seconds)
RECEIPT_TIMEOUT=120
# Gas price bump on nonce-conflict retry (bps; 10000=no bump, 12000=+20%)
RETRY_GAS_PRICE_BUMP_BPS=12000

# Prefer QuickNode (true/false)
# true  = use QuickNode (requires QUICKNODE_HTTP_URL and QUICKNODE_WS_URL)
# false = use public BSC endpoints (requires BSC_RPC_URL)
USE_QUICKNODE=true

# Prefer WebSocket (true/false)
# true  = prefer WebSocket connections (push-based, recommended)
# false = use HTTP polling
USE_WEBSOCKET=true

# Subscription mode (used by listen_deposits.py)
# true  = prefer eth_subscribe(logs) push (when supported by the node)
# false = disable subscription and only use concurrent getLogs polling
USE_SUBSCRIPTION=true
# Delay before falling back to polling after subscription errors (seconds)
SUBSCRIPTION_RECONNECT_DELAY=3

# Confirmations (reorg safety): only process sufficiently confirmed blocks
# 0 = do not wait for confirmations (faster, but small reorg risk)
CONFIRMATIONS=3

# Scheduled task config (used by call_poke.py)
POKE_CHECK_INTERVAL=3600

# ================================
# Telegram Bot (optional)
# ================================
# Telegram Bot token (create one via BotFather)
TELEGRAM_BOT_TOKEN=
# Optional: if empty, the bot will read it from Controller.naio()
NAIO_TOKEN_ADDRESS=

# Broadcast toggles (Telegram Bot)
TELEGRAM_BOT_BROADCAST_DEPOSITS=true
# Deflation broadcast (DeflationExecuted)
TELEGRAM_BOT_BROADCAST_DEFLATION=true
# Ops broadcast (claim/withdraw/node rewards, etc.)
TELEGRAM_BOT_BROADCAST_OPS=true

# Referral cold-start distributor (required by deploy script): will be funded with 1000 NAIO during deployment
# This address sends 0.001 NAIO to new users to bootstrap referral binding, but does NOT earn referral rewards
REFERRAL_BOOTSTRAP_ADDRESS=

# ================================
# Keeper validator (independent supervision; recommended)
# ================================
# Validator confirmations (recommended >= 3)
VALIDATOR_CONFIRMATIONS=3
# Validator polling interval (seconds)
VALIDATOR_POLL_INTERVAL=12
# Validator state file
VALIDATOR_STATE_FILE=keeper_validator_state.json
# Enable veto (call validatorVetoPause when anomalies are detected)
VALIDATOR_VETO_ENABLED=true
# Dedicated validator Telegram bot (separate from the main bot)
VALIDATOR_TELEGRAM_BOT_TOKEN=
# Multiple recipients (recommended; supports DM/group/channel)
# Accepts JSON array, e.g. ["123456789","-1001234567890"]
# Or comma-separated, e.g. 123456789,-1001234567890
VALIDATOR_TELEGRAM_CHAT_IDS=
# Default alert language (zh-CN / zh-TW / en-US / ko / ja / th)
VALIDATOR_TELEGRAM_LANG=zh-CN
# Enable /lang command (polls getUpdates and persists to the state file)
VALIDATOR_TELEGRAM_ENABLE_COMMANDS=true
# Optional: validator bot username (without @). Used to match /lang@<bot> in groups.
# If empty, it will be fetched via getMe automatically.
VALIDATOR_TELEGRAM_BOT_USERNAME=
# Gas balance alert threshold (BNB)
VALIDATOR_GAS_ALERT_THRESHOLD_BNB=0.01
# Gas balance check interval (seconds)
VALIDATOR_GAS_CHECK_INTERVAL=300
# Extra gas watch addresses (optional)
# By default it watches validator + keeper + witness signers; if KEEPER_COUNCIL_MEMBER_1..5 are set they are included too.
# Use this to add emergency ops addresses, etc. (JSON array or comma-separated)
# Example: ["0xabc...","0xdef..."] or 0xabc...,0xdef...
VALIDATOR_GAS_WATCH_ADDRESSES=
# Optional: override language per chat_id (JSON object)
# Example: {"123456789":"en-US","-1001234567890":"zh-CN"}
VALIDATOR_TELEGRAM_CHAT_LANG_MAP=
# Backward compatibility (single chat id; used when VALIDATOR_TELEGRAM_CHAT_IDS is empty)
VALIDATOR_TELEGRAM_CHAT_ID=

# Price recording & candles (Telegram Bot)
PRICE_DB_PATH=price_history.db
PRICE_RECORD_INTERVAL=1
PRICE_CANDLE_INTERVAL=60
PRICE_RETENTION_DAYS=7
PRICE_PIC_SIMULATE=false
PRICE_PIC_CANDLE_COUNT=60
