# Witness Signer Service - example dotenv file
#
# Copy this file to a private per-signer env file, e.g.:
#   backend/witness_signer/envs/signer1.env
#   backend/witness_signer/envs/signer2.env
#   backend/witness_signer/envs/signer3.env
#
# IMPORTANT:
# - Do NOT commit your real env files (private keys / API keys).
# - Your real env files are ignored by the root .gitignore (signer*.env).
#
# The service reads dotenv via WITNESS_SIGNER_DOTENV_PATH (or defaults to backend/.env).
# If you use this file, make sure to start the signer with:
#   WITNESS_SIGNER_DOTENV_PATH=/opt/naio/backend/witness_signer/envs/signer1.env \
#   python /opt/naio/backend/witness_signer/witness_signer_service.py
#

# Hub base URL (publicly reachable from this signer machine).
# Example: http://hub-host:8787
WITNESS_HUB_SERVER_URL=

# Optional API key sent as HTTP header `X-Api-Key`.
# Usually the same value as the Hub's WITNESS_HUB_API_KEY.
WITNESS_SIGNER_API_KEY=

# Signer private key for this machine (NEVER share / NEVER commit).
# Accepts hex with or without 0x prefix.
WITNESS_SIGNER_PRIVATE_KEY=

# Optional: expected signer address (derived from the private key).
# If set, the service will refuse to start when it doesn't match.
WITNESS_SIGNER_EXPECTED_ADDRESS=

# Polling interval (seconds). Default: 2
WITNESS_SIGNER_POLL_INTERVAL_SECONDS=2

# HTTP timeout (seconds). Default: 10 (min enforced by code: 3)
WITNESS_SIGNER_HTTP_TIMEOUT_SECONDS=10

# Optional log level: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

